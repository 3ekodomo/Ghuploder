{
  "name": "GH Uploader",
  "short_name": "Uploader",
  "start_url": "./index.html", 
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2ea44f",
  "icons": [
    {
      "src": "https://github.githubassets.com/images/modules/logos_page/GitHub-Mark.png",
      "sizes": "192x192",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "./share-target", 
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "file",
          "accept": ["image/*", "application/pdf", "text/plain", "*/*"]
        }
      ]
    }
  }
}
